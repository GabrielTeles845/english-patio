# Google Apps Script URL (Backend Seguro)
# Cole aqui a URL do Web App após fazer o deploy no Google Apps Script
# Siga as instruções em INSTRUCOES-CONFIGURACAO.md
# Exemplo: https://script.google.com/macros/s/ABC123XYZ.../exec
VITE_GOOGLE_APPS_SCRIPT_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Dashboard administrativa (backend serverless + Neon) — DASHBOARD_PLAN §2/§3
# ──────────────────────────────────────────────────────────────────────────────
# Connection string do Neon (Postgres). Usada pelas funções em api/.
DATABASE_URL=

# Segredo de assinatura dos JWTs de sessão. Gere um aleatório, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Bootstrap do 1º Diretor no deploy (DASHBOARD_SCHEMA.sql §users).
# Default do plano: admin@email.com / Senh@12345 (10 chars, política VALIDACOES §8),
# com troca de senha obrigatória no 1º acesso.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Web Push — notificações do navegador/SO (server/lib/webpush.ts).
# Gere o par com: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Sem estas, o push fica desligado (no-op). A privada é SEGREDO — nunca commitar.
# VAPID_SUBJECT é opcional (default mailto:contato@englishpatio.com.br).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
