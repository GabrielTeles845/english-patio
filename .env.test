# Ambiente da suíte de testes (npm run test:api). Aponta para o Postgres local
# (Docker, docker-compose.test.yml), NUNCA para o Neon de dev/prod. Estes valores
# NÃO são segredos: o banco é local/efêmero e o JWT_SECRET serve só para a suíte.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/english_patio_test
JWT_SECRET=test-secret-apenas-para-a-suite-local-nao-use-em-producao
SEED_ADMIN_EMAIL=admin@email.com
SEED_ADMIN_PASSWORD=Senh@12345
NODE_ENV=test
